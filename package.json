{
  "name": "nextjs-fullstack-framework",
  "version": "1.0.0",
  "description": "Next.js 16+ 全栈框架 - 前后端分离架构，支持 PostgreSQL 和 Redis",
  "private": false,
  "keywords": [
    "nextjs",
    "fullstack",
    "prisma",
    "redis",
    "postgresql"
  ],
  "author": "hot1976",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@tanstack/react-query": "^5.99.0",
    "ioredis": "^5.10.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^1.2.0"
  }
}
